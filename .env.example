# ──────────────────────────────────────────────
#  Medical Diagnostic System — Environment Keys
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────

# HuggingFace (for ClinicalBERT + model hub)
HUGGINGFACE_API_TOKEN=

# OpenAI (GPT-based summarisation agent)
OPENAI_API_KEY=

# FastAPI / Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ML Pipeline
MODEL_CHECKPOINT_DIR=./ml_pipeline/checkpoints
LOG_LEVEL=INFO
